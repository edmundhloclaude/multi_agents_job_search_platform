# Copy to .env and fill in. .env is git-ignored and auto-loaded by the CLI.
# Real environment variables always take precedence over .env values.

# TheirStack job-postings API (https://app.theirstack.com → Settings → API keys)
THEIRSTACK_API_KEY=

# OpenAI (only if llm.provider=openai or using the OpenAI browser controller)
# OPENAI_API_KEY=
